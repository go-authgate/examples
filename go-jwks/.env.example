# ─── Required by main.go (resource server) ────────────────────────────

# AuthGate issuer URL — must match the `iss` claim of the tokens you
# want to validate and the `issuer` field of its OIDC discovery document.
ISSUER_URL=https://auth.example.com

# Required `aud` claim value. Leave unset or empty to disable audience
# enforcement (useful when AuthGate doesn't emit `aud` on access tokens).
EXPECTED_AUDIENCE=

# ─── Required by get-token.sh (Client Credentials helper) ─────────────
# Not used by main.go — it only validates tokens, never mints them.

CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# Space-separated scopes to request. Default "email profile" matches the
# AuthGate out-of-the-box scope set. Override with --scope on the CLI.
SCOPE=email profile

# Set to 1 to pass -k to curl (skip TLS verification). Dev only — useful
# when AuthGate runs with a self-signed certificate on localhost.
INSECURE=0
